{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comentario": "Perfil PESSOAL — econômico. Postura relaxada de confidencialidade, mas segredos seguem bloqueados.",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(cat *.env*)",
      "Bash(env)",
      "Bash(printenv*)"
    ],
    "ask": [
      "Bash(git push*)"
    ]
  }
}
